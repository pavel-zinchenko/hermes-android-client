<?xml version="1.0" encoding="utf-8"?>
<!--
  Hermes runs on the same device as the app and is reached over plain HTTP on
  loopback. Android blocks cleartext by default (API 28+), so we explicitly allow
  it only for localhost. 10.0.2.2 is the host loopback alias used by the Android
  emulator (for dev iteration against a Hermes server on the dev machine).
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>
</network-security-config>
